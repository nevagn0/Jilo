@model User
@{
    ViewData["Title"] = "Registration";
}
<form asp-action="Index" enctype="multipart/form-data" method="post">
    <div aligh="center">
        <div>
            <button asp-controller="Back" asp-action="RegistrationBack">Назад</button>
        </div>
        <label asp-for="Username">Имя</label>
        <input asp-for="Username" placeholder="Введите ваш никнем" />
        <span asp-validation-for="Username"></span>
    </div>
    <div>
        <label asp-for="Email"></label>
        <input asp-for="Email" placeholder="Введите почту"/>
        <span asp-validation-for="Email"></span>
    </div>
    <div>
        <label asp-for="Passwordhash"></label>
        <input asp-for="Passwordhash" placeholder="Введите пароль"/>
        <span typeof="passsword" asp-validation-for="Passwordhash"></span>
    </div>
    <div>
        <label asp-for="Avatar">Фото</label>
        <input asp-for="Avatar" type="file" name="avatarFile" accept="image/*" />
    </div>
    <div>
        <button type="submit">Зарегистрироваться</button>
    </div>
</form>
