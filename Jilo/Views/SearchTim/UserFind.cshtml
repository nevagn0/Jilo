@model User
@{
    ViewData["Title"] = "UserFind";
}
    <div class="profile-container">
        <div class="profile-header">
            <img src="@Model.Avatar" class="profile-avatar">
            <h1>@Model.Username</h1>
            <p>Зарегистрирован: @Model.DataRegistration.ToShortDateString()</p>
            <p>Последний раз онлайн: @Model.LastOnline</p>
        </div>

        <div class="profile-games">
            <h2>Игры пользователя:</h2>
            @foreach (var gameUser in Model.GamesUsers)
            {
                <div class="game-card">
                    <h3>@gameUser.IdGameNavigation.Name</h3>
                    <p>Роль: @gameUser.Role</p>
                </div>
            }
        </div>

        <div>
            <h2>Комментарии:</h2>
            @foreach (var comm in ViewBag.Comments)
            {
            <div class="comment">
                <img src="@comm.IdUserNavigation?.Avatar" class="comment-avatar" />
                <div>
                    <p><strong>@comm.IdUserNavigation?.Username:</strong> @comm.Comm1</p>
                    <p>Оценка: @comm.Grade</p>
                </div>
            </div>
            }
        </div>

        <form asp-controller="SearchTim" asp-action="AddComm" method="post">
            <input type="hidden" name="targetUser" value="@Model.Id" />
            <div>
                <input type="text" name="comm" placeholder="Напишите комментарий" />
            </div>
            <div>
                <input type="number" name="grade" min="1" max="5" step="0.1" placeholder="Оценка (1-5)" />
            </div>
            <button type="submit">Отправить</button>
        </form>
    </div>