@model List<GamesUser>
@{
    ViewData["Title"] = "Мои игры";
}

<div class="container mt-4">
    <h2>Мои игры</h2>
    <table class="table table-bordered">
        <thead class="thead-light">
            <tr>
                <th>Название игры</th>
                <th>Ранг</th>
                <th>Роль</th>
                <th>Время в игре</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var game in Model)
            {
                <tr>
                    <td>@game.IdGameNavigation?.Name</td>
                    <form method="post" asp-action="Update" asp-controller="UpdateOrDelete">
                        <input type="hidden" name="idUser" value="@game.IdUser" />
                        <input type="hidden" name="idGame" value="@game.IdGame" />
                    <td>
                        <div class="input-group">
                            <input type="text" name="Rank" value="@game.Rank" class="form-control form-control-sm" />
                        </div>
                    </td>
                    <td>
                        <div class="input-group">
                            <input type="text" name="Role" value="@game.Role" class="form-control form-control-sm" />
                        </div>
                    </td>
                    <td>
                        <div class="input-group">
                            <input type="text" name="TimeInGame" value="@game.TimeInGame" class="form-control form-control-sm" />
                        </div>
                    </td>
                    <td>
                        <button type="submit" class="btn btn-sm btn-outline-primary">Сохранить</button>
                    </td>
                    </form>
                    <td>
                        <form method="post" asp-action="Delete" asp-controller="UpdateOrDelete">
                            <input type="hidden" name="idUser" value="@game.IdUser" />
                            <input type="hidden" name="idGame" value="@game.IdGame" />
                            <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
