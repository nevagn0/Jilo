    SELECT u.id, u.avatar, u.comm, u.data_registration, u.discription, u.email, u.grade, u.last_online, u.passwordhash, u.\"Role\", u.socialcredits, u.username
    FROM \"User\" AS u
    WHERE u.username = @__name_0
    LIMIT 1
) AS u0
LEFT JOIN (
    SELECT g.id_user, g.id_game, g.rank, g.role, g.time_in_game, g0.id, g0.avatar, g0.discrip, g0.name
    FROM games_user AS g
    INNER JOIN games AS g0 ON g.id_game = g0.id
) AS s ON u0.id = s.id_user
LEFT JOIN comm AS c ON u0.id = c.id_user
ORDER BY u0.id, s.id_user, s.id_game, s.id"
