@model User
@{
    ViewData["Title"] = "Profile";
}

<div class="profile-container">
    <img src="@Model.Avatar" class="avatar" alt="Аватар" style="width: 100px; border-radius: 50%;">
    <h1>Профиль пользователя @Model.Username</h1>
    <p>Всего игр: @ViewBag.GameCount</p>

    @if (ViewBag.AllGames != null && ViewBag.AllGames.Count > 0)
    {
        <h3>Список игр:</h3>
        <ul>
            @foreach (var gameUser in ViewBag.AllGames)
            {
                <li>
                    @gameUser.IdGameNavigation.Name -
                    Ранг: @gameUser.Rank,
                    Роль: @gameUser.Role
                </li>
            }
        </ul>
    }
    else
    {
        <p>У пользователя пока нет игр</p>
    }
</div>