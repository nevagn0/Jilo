@model List<Game>
@{
    ViewData["Title"] = "Создание объявления";
}

<div class="create-page">
    <div class="create-container">
        <!-- Кнопка Назад -->
        <form asp-controller="Back" asp-action="AddGames" method="post" class="create-back-form">
            <button type="submit" class="create-back-btn">
                <i class="fas fa-arrow-left"></i> Назад
            </button>
        </form>

        <div class="create-header">
            <h1 class="create-title">Создать новое объявление</h1>
            <p class="create-subtitle">Заполните информацию о вашем объявлении</p>
        </div>

        <!-- Блок для отображения сообщений -->
        @if (ViewBag.Message != null)
        {
            <div class="create-message @(ViewBag.MessageType == "success" ? "create-message-success" : "create-message-error")">
                @ViewBag.Message
            </div>
        }

        <form asp-controller="AddAdversmet" asp-action="CreateVersment" method="post" class="create-form">
            <div class="create-form-group">
                <label class="create-label">Выберите игру:</label>
                <select name="selectedGameId" class="create-select" required>
                    @foreach (var game in ViewBag.game)
                    {
                        <option value="@game.Id">@game.Name</option>
                    }
                </select>
            </div>

            <div class="create-form-group">
                <label class="create-label">Описание объявления:</label>
                <textarea name="discription" class="create-textarea" placeholder="Опишите что вы предлагаете или ищете" required></textarea>
            </div>

            <button type="submit" class="create-submit-btn">Создать объявление</button>
        </form>
    </div>
</div>

