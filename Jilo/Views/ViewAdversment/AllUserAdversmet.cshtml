@model List<AdversmetUser>

@{
	ViewData["Title"] = "Мои объявления";
}
<form asp-action="AllUserAdverstmet">
    <div>
        <button asp-controller="Back" asp-action="Profile">Назад</button>
    </div>
    @if (Model.Any())
    {
        <div class="row">
            @foreach (var ad in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@ad.IdGameNavigation.Name</h5>
                            <h6 class="card-subtitle mb-2 text-muted">
                                Автор: @ad.IdUserNavigation.Username
                            </h6>
                            <h6 class="card-subtitle mb-2 text-muted">
                                Откликнулся:
                                <a asp-controller="ViewAdversment"
                                   asp-action="SecondUserProfileOpen"
                                   asp-route-username="@ad.NameSecondUser">
                                    @ad.NameSecondUser
                                </a>
                            </h6>
                            <p class="card-text"> Описание: @ad.Discription</p>
                            <p class="card-text">
                                <small class="text-muted">
                                    Дата создания: @ad.DateCreate?.ToString("dd.MM.yyyy")
                                </small>
                            </p>

                            @if (ad.IdSecondUser == null)
                            {
                                <form asp-action="RespondToAd" method="post">
                                    <input type="hidden" name="idUser" value="@ad.IdUser" />
                                    <input type="hidden" name="idGame" value="@ad.IdGame" />
                                </form>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    На это объявление уже откликнулись
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">Объявлений пока нет</div>
    }
</form>