@model User
@{
    ViewData["Title"] = "Профиль пользователя";
}

<div class="userfind-page">
    <div class="userfind-container">
        <button onclick="window.history.back()" type="submit" class="userfind-back-btn">
                <i class="fas fa-arrow-left"></i> Назад
            </button>

        <div class="userfind-header">
            <img src="@Model.Avatar" class="userfind-avatar">
            <div class="userfind-info">
                <h1 class="userfind-username">@Model.Username</h1>
                <div class="userfind-meta">
                    <span class="userfind-meta-item">Зарегистрирован: @Model.DataRegistration.ToShortDateString()</span>
                    <span class="userfind-meta-item">Последний раз онлайн: @Model.LastOnline</span>
                </div>
            </div>
        </div>

        <div class="userfind-section">
            <h2 class="userfind-section-title">Описание</h2>
            <div class="userfind-description">
                @if (string.IsNullOrEmpty(Model.Discription))
                {
                    <p class="userfind-no-description">Описания пока нет :(, Добавьте источники где с вами смогут связаться другие игроки.</p>
                }
                else
                {
                    <p class="userfind-description-text">@Model.Discription</p>
                }
            </div>
        </div>

        <div class="userfind-section">
            <h2 class="userfind-section-title">Игры пользователя</h2>
            <div class="userfind-games">
                @if (Model.GamesUsers != null && Model.GamesUsers.Any())
                {
                    @foreach (var gameUser in Model.GamesUsers)
                    {
                        <div class="userfind-game-card">
                            <h3 class="userfind-game-name">@gameUser.IdGameNavigation.Name</h3>
                            <p class="userfind-game-role">Роль: @gameUser.Role</p>
                            <p class="userfind-game-rank">Ранг: @gameUser.Rank</p>
                        </div>
                    }
                }
                else
                {
                    <p class="userfind-no-games">Пользователь пока не добавил игры</p>
                }
            </div>
        </div>

        <div class="userfind-section">
            <h2 class="userfind-section-title">Комментарии</h2>
            <div class="userfind-comments">
                @if (ViewBag.Comments != null && ViewBag.Comments.Count > 0)
                {
                    @foreach (var comm in ViewBag.Comments)
                    {
                        <div class="userfind-comment">
                            <img src="@comm.IdUserNavigation?.Avatar" class="userfind-comment-avatar" />
                            <div class="userfind-comment-content">
                                <div class="userfind-comment-header">
                                    <strong class="userfind-comment-author">@comm.IdUserNavigation?.Username</strong>
                                    <span class="userfind-comment-rating">Оценка: @comm.Grade</span>
                                </div>
                                <p class="userfind-comment-text">@comm.Comm1</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="userfind-no-comments">Пока нет комментариев</p>
                }
            </div>
        </div>
        <div>
            <p>Cредняя оценка: @(ViewBag.SocialCredits?.ToString("0.00") ?? "нет данных")</p>
        </div>
            <div class="userfind-section">
                <h2 class="userfind-section-title">Оставить комментарий</h2>
                <form asp-controller="SearchTim" asp-action="AddComm" method="post" class="userfind-comment-form">
                    <input type="hidden" name="targetUser" value="@Model.Id" />
                    <div class="userfind-form-group">
                        <textarea name="comm" class="userfind-comment-input" placeholder="Напишите комментарий" required></textarea>
                    </div>
                    <div class="userfind-form-group">
                        <input type="number" name="grade" min="1" max="5" step="0.1" class="userfind-rating-input" placeholder="Оценка (1-5)" required>
                    </div>
                    <button type="submit" class="userfind-submit-btn">Отправить</button>
                </form>
            </div>
    </div>
</div>

<script>
    document.querySelector('.userfind-comment-form')?.addEventListener('submit', function(e) {
    @if (!User.Identity.IsAuthenticated)
    {
        <text>
                    e.preventDefault();
                    window.location.href = '@Url.Action("Index", "Registration")?returnUrl=' +
                        encodeURIComponent('@Url.Action("UserFind", new { name = Model.Username })');
        </text>
    }
    });
</script>