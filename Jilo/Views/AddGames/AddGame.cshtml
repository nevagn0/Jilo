@model List<Game>
@{
    ViewData["Title"] = "Выбор игр";
}
<div class="container">
    <h2 class="my-4">Выберите свои игры</h2>
    <div>
        <button onclick="window.history.back()">Назад</button>
    </div>
    <div class="row">
        @foreach (var game in Model)
        {
            <form asp-controller="AddGames" asp-action="AddGame" method="post">
             <input type="hidden" name="__RequestVerificationToken" value="@Html.AntiForgeryToken()" />
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <img src="@game.Avatar" class="card-img-top" alt="@game.Name" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">@game.Name</h5>
                            <p class="card-text">@game.Discrip</p>

                            <input type="hidden" name="gameId" value="@game.Id" />

                            <div class="mb-3">
                                <label class="form-label">Ранг</label>
                                <select name="rank" class="form-select">
                                    <option value="Новичок">Новичок</option>
                                    <option value="Любитель">Любитель</option>
                                    <option value="Опытный">Опытный</option>
                                    <option value="Эксперт">Эксперт</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Роль</label>
                                <input type="text" name="role" class="form-control" placeholder="Ваша роль в игре" value="Игрок">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Часы в игре</label>
                                <input type="text" name="TimeInGame" class="form-control" placeholder="Часы">
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Добавить игру</button>
                        </div>
                    </div>
                </div>
            </form>
        }
    </div>
</div>