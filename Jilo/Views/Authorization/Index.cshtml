@model Jilo.Dto.LoginDto
@{
    ViewData["Title"] = "Authorization";
}
<div class="registration-page">
    <div class="registration-container">
        <form asp-controller="Back" asp-action="RegistrationBack" method="post">
            <button class="back-btn">
                <i class="fas fa-arrow-left"></i> Назад
            </button>
        </form>

        <div class="registration-header">
            <h1 class="registration-title">Вход в аккаунт</h1>
            <p class="registration-subtitle">Войдите в свой аккаунт Jilo</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        }

        <form asp-action="Authorization" method="post">
            <div class="form-group">
                <label asp-for="Username" class="form-label">Имя пользователя</label>
                <input asp-for="Username" class="form-control @(ViewData.ModelState["Username"]?.Errors.Count > 0 ? "is-invalid" : "")" placeholder="Введите ваш никнейм" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Пароль</label>
                <input asp-for="Password" type="password" class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" placeholder="Введите пароль" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div>
                <button type="submit" class="btn-register">Вход</button>
            </div>
        </form>

        <div class="login-link">
            Нет аккаунта? <a asp-controller="Registration" asp-action="Index">Зарегистрируйтесь</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}