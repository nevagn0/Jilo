@model List<AdversmetUser>
@{
    ViewData["Title"] = "Мои объявления";
}

<div class="adversmet-page">
    <div class="adversmet-container">
        <form asp-controller="Back" asp-action="Profile" method="post" class="adversmet-back-form">
            <button type="submit" class="adversmet-back-btn">
                <i class="fas fa-arrow-left"></i> Назад
            </button>
        </form>

        <div class="adversmet-header">
            <h1 class="adversmet-title">Мои объявления</h1>
        </div>

        @if (TempData["Message"] != null)
        {
            <div class="adversmet-message @(TempData["MessageType"]?.ToString() == "success" ? "adversmet-message-success" : "adversmet-message-error")">
                @TempData["Message"]
            </div>
        }

        @if (Model.Any())
        {
            <div class="adversmet-grid">
                @foreach (var ad in Model)
                {
                    <div class="adversmet-card">
                        <div class="adversmet-card-body">
                            <h3 class="adversmet-card-title">@ad.IdGameNavigation.Name</h3>
                            <div class="adversmet-card-meta">
                                <span>Дата создания: @ad.DateCreate?.ToString("dd.MM.yyyy")</span>
                            </div>
                            <p class="adversmet-card-text">@ad.Discription</p>

                            @if (ad.IdSecondUser != null)
                            {
                                <div class="adversmet-card-response">
                                    <span>Откликнулся:</span>
                                    <a asp-controller="ViewAdversment"
                                       asp-action="SecondUserProfileOpen"
                                       asp-route-username="@ad.NameSecondUser">
                                        @ad.NameSecondUser
                                    </a>
                                </div>
                            }

                            <form asp-controller="UpdateOrDelete" asp-action="DeleteAdverstment" method="post"
                                  class="adversmet-delete-form">
                                <input type="hidden" name="idUser" value="@ad.IdUser" />
                                <input type="hidden" name="idGame" value="@ad.IdGame" />
                                <button type="submit" class="adversmet-delete-btn">
                                    Удалить объявление
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="adversmet-empty">
                У вас пока нет объявлений
            </div>
        }
    </div>
</div>

